# ─── Public site ────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://arabclue.com
# Salla App Store install URL (marketing CTAs) — falls back to /signup if unset
NEXT_PUBLIC_SALLA_INSTALL_URL=

# Optional distributed rate limiting (falls back to in-memory)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional error tracking (structured JSON logs always; Sentry when set)
SENTRY_DSN=

# Optional — disable server-side analytics event logging
ANALYTICS_DISABLED=

# ─── Supabase ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── AI providers ───────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# For PDPL-residency in-Kingdom inference (optional, when wired):
HUMAIN_API_BASE=
HUMAIN_API_KEY=

# ─── Salla App ──────────────────────────────────────────────────────────────
SALLA_CLIENT_ID=
SALLA_CLIENT_SECRET=
SALLA_REDIRECT_URI=https://arabclue.com/api/salla/oauth/callback
SALLA_WEBHOOK_SECRET=

# ─── ZATCA / Fatoora (set after CSID onboarding) ────────────────────────────
ZATCA_FATOORA_BASE=https://gw-fatoora.zatca.gov.sa/e-invoicing/developer-portal
ZATCA_CSID=
ZATCA_PRIVATE_KEY_PEM=

# ─── Wathq (B2B intelligence) ───────────────────────────────────────────────
WATHQ_API_KEY=

# ─── Social platform connectors ─────────────────────────────────────────────
# Meta (Instagram + WhatsApp Business) — OAuth redirect
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=https://arabclue.com/api/oauth/meta/callback
META_WEBHOOK_VERIFY_TOKEN=
# Legacy env fallbacks (optional if using per-merchant OAuth)
META_IG_USER_ID=
META_PAGE_ACCESS_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_ACCESS_TOKEN=
# Per-employee WhatsApp webhook verification (fallback when integration has no verify_token)
WHATSAPP_VERIFY_TOKEN=

# Slack Events API (optional fallback if signing_secret not stored per employee)
SLACK_SIGNING_SECRET=

# LinkedIn OAuth
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=https://arabclue.com/api/oauth/linkedin/callback
LINKEDIN_ACTOR_URN=
LINKEDIN_ACCESS_TOKEN=

# X (Twitter) OAuth 2.0
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=https://arabclue.com/api/oauth/x/callback
X_BEARER=

# TikTok OAuth
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=https://arabclue.com/api/oauth/tiktok/callback
TIKTOK_ACCESS_TOKEN=

# OAuth state signing + social inbound bridge (defaults to CRON_SECRET if unset)
OAUTH_STATE_SECRET=
SOCIAL_INBOUND_SECRET=

# Platform admin (comma-separated emails allowed to access /admin)
PLATFORM_ADMIN_EMAILS=

# Encrypt OAuth tokens at rest (32+ char random string — required in production)
TOKEN_ENCRYPTION_KEY=

# Voice telephony bridge
VOICE_BRIDGE_SECRET=
VOICE_BRIDGE_WS_URL=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# ISO country for number search (SA for production; US for sandbox testing)
TWILIO_NUMBER_COUNTRY=SA

# ─── Payments (Moyasar) ─────────────────────────────────────────────────────
MOYASAR_PUBLIC_KEY=
NEXT_PUBLIC_MOYASAR_PUBLIC_KEY=
MOYASAR_SECRET_KEY=
MOYASAR_WEBHOOK_SECRET=

# ─── Cron auth ──────────────────────────────────────────────────────────────
CRON_SECRET=change-me-to-a-strong-random-string
